# Copy to skill-runtime.env (next to this file) for local overrides.
# Keep this file committed; keep skill-runtime.env untracked.
# Source it in any agent before running Mesa scripts, e.g.:
#   source abm-modeling/skill-runtime.env.example

# Python 3.10+ interpreter used for Mesa runs and the configuration page runner.
ABM_MESA_PYTHON=python3.12

# Workspace-local Mesa/Solara dependency cache. Do not use /tmp for normal work.
ABM_MESA_INSTALL_DIR=.abm-mesa-env

# Default location for local experiment outputs.
ABM_MESA_OUTPUT_ROOT=outputs
