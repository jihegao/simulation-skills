{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simulation-skills.local/contracts/v0.1/model-spec.schema.json",
  "x-contract-id": "simulation.model_spec",
  "x-schema-version": "0.1.0",
  "title": "Simulation Model Spec 0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract", "schema_version", "object_id", "revision", "parent_revision",
    "created_at", "created_by", "provenance", "extensions",
    "system_boundary", "time_semantics", "parameters", "metrics", "method_payload_ref",
    "domain_extensions", "assumptions", "implementation_artifact_ref"
  ],
  "allOf": [{"if": {"properties": {"revision": {"const": 1}}, "required": ["revision"]}, "then": {"properties": {"parent_revision": {"type": "null"}}}, "else": {"properties": {"parent_revision": {"type": "integer", "minimum": 1}}}}],
  "properties": {
    "contract": {"const": "simulation.model_spec"},
    "schema_version": {"const": "0.1.0"},
    "object_id": {"$ref": "common.schema.json#/$defs/identifier"},
    "revision": {"type": "integer", "minimum": 1},
    "parent_revision": {"type": ["integer", "null"], "minimum": 1},
    "created_at": {"$ref": "common.schema.json#/$defs/utcTimestamp"},
    "created_by": {"$ref": "common.schema.json#/$defs/actor"},
    "provenance": {"$ref": "common.schema.json#/$defs/provenance"},
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"},
    "system_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["included", "excluded"],
      "properties": {
        "included": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "excluded": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    },
    "time_semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "base_unit", "start", "end"],
      "properties": {
        "mode": {"enum": ["discrete_event", "discrete_step"]},
        "base_unit": {"$ref": "common.schema.json#/$defs/unit"},
        "start": {"type": "number"},
        "end": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "common.schema.json#/$defs/parameter"}
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "common.schema.json#/$defs/metricDefinition"}
    },
    "method_payload_ref": {
      "oneOf": [
        {
          "allOf": [
            {"$ref": "common.schema.json#/$defs/objectRef"},
            {"properties": {"contract": {"const": "simulation.des_method_payload"}, "schema_version": {"const": "0.1.0"}}}
          ]
        },
        {
          "allOf": [
            {"$ref": "common.schema.json#/$defs/objectRef"},
            {"properties": {"contract": {"const": "simulation.abm_method_payload"}, "schema_version": {"const": "0.1.0"}}}
          ]
        }
      ]
    },
    "domain_extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["namespace", "schema_ref", "payload"],
        "properties": {
          "namespace": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_]*){2,}$"},
          "schema_ref": {"type": "string", "minLength": 1, "maxLength": 512},
          "payload": {"type": "object"}
        }
      }
    },
    "assumptions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "implementation_artifact_ref": {"oneOf": [{"$ref": "common.schema.json#/$defs/artifactRef"}, {"type": "null"}]}
  }
}
