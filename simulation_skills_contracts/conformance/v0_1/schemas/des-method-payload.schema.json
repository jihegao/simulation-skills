{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simulation-skills.local/contracts/v0.1/des-method-payload.schema.json",
  "x-contract-id": "simulation.des_method_payload",
  "x-schema-version": "0.1.0",
  "title": "Discrete-event Method Payload 0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract", "schema_version", "object_id", "revision", "parent_revision",
    "created_at", "created_by", "provenance", "extensions",
    "time_unit", "horizon", "entity_types", "arrival_processes", "resources",
    "process_steps", "routing", "output_metrics"
  ],
  "allOf": [{"if": {"properties": {"revision": {"const": 1}}, "required": ["revision"]}, "then": {"properties": {"parent_revision": {"type": "null"}}}, "else": {"properties": {"parent_revision": {"type": "integer", "minimum": 1}}}}],
  "properties": {
    "contract": {"const": "simulation.des_method_payload"},
    "schema_version": {"const": "0.1.0"},
    "object_id": {"$ref": "common.schema.json#/$defs/identifier"},
    "revision": {"type": "integer", "minimum": 1},
    "parent_revision": {"type": ["integer", "null"], "minimum": 1},
    "created_at": {"$ref": "common.schema.json#/$defs/utcTimestamp"},
    "created_by": {"$ref": "common.schema.json#/$defs/actor"},
    "provenance": {"$ref": "common.schema.json#/$defs/provenance"},
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"},
    "time_unit": {"$ref": "common.schema.json#/$defs/unit"},
    "horizon": {"type": "number", "exclusiveMinimum": 0},
    "entity_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entity_type_id"],
        "properties": {"entity_type_id": {"$ref": "common.schema.json#/$defs/identifier"}}
      }
    },
    "arrival_processes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["arrival_id", "entity_type_id", "distribution", "parameters"],
        "properties": {
          "arrival_id": {"$ref": "common.schema.json#/$defs/identifier"},
          "entity_type_id": {"$ref": "common.schema.json#/$defs/identifier"},
          "distribution": {"enum": ["deterministic", "exponential", "schedule"]},
          "parameters": {"type": "array", "minItems": 1, "items": {"$ref": "common.schema.json#/$defs/parameter"}}
        }
      }
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resource_id", "capacity", "capacity_unit"],
        "properties": {
          "resource_id": {"$ref": "common.schema.json#/$defs/identifier"},
          "capacity": {"type": "integer", "minimum": 1},
          "capacity_unit": {"$ref": "common.schema.json#/$defs/unit"}
        }
      }
    },
    "process_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "resource_id", "service_distribution", "parameters"],
        "properties": {
          "step_id": {"$ref": "common.schema.json#/$defs/identifier"},
          "resource_id": {"$ref": "common.schema.json#/$defs/identifier"},
          "service_distribution": {"enum": ["deterministic", "exponential", "triangular"]},
          "parameters": {"type": "array", "minItems": 1, "items": {"$ref": "common.schema.json#/$defs/parameter"}}
        }
      }
    },
    "routing": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from_step_id", "to_step_id", "probability"],
        "properties": {
          "from_step_id": {"$ref": "common.schema.json#/$defs/identifier"},
          "to_step_id": {"$ref": "common.schema.json#/$defs/identifier"},
          "probability": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "output_metrics": {"type": "array", "minItems": 1, "items": {"$ref": "common.schema.json#/$defs/metricDefinition"}}
  }
}
