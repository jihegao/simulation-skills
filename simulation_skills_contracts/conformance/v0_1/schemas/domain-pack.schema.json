{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simulation-skills.local/contracts/v0.1/domain-pack.schema.json",
  "x-contract-id": "simulation.domain_pack",
  "x-schema-version": "0.1.0",
  "title": "Simulation Domain Pack 0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract", "schema_version", "object_id", "revision", "parent_revision",
    "created_at", "created_by", "provenance", "extensions",
    "pack_id", "pack_version", "compatible_modeling_ir", "method_payload_contracts",
    "scenario_templates", "default_experiment_templates", "metric_definitions",
    "visualization_hints", "adapter_requirements", "validation_fixture_refs"
  ],
  "allOf": [{"if": {"properties": {"revision": {"const": 1}}, "required": ["revision"]}, "then": {"properties": {"parent_revision": {"type": "null"}}}, "else": {"properties": {"parent_revision": {"type": "integer", "minimum": 1}}}}],
  "properties": {
    "contract": {"const": "simulation.domain_pack"},
    "schema_version": {"const": "0.1.0"},
    "object_id": {"$ref": "common.schema.json#/$defs/identifier"},
    "revision": {"type": "integer", "minimum": 1},
    "parent_revision": {"type": ["integer", "null"], "minimum": 1},
    "created_at": {"$ref": "common.schema.json#/$defs/utcTimestamp"},
    "created_by": {"$ref": "common.schema.json#/$defs/actor"},
    "provenance": {"$ref": "common.schema.json#/$defs/provenance"},
    "extensions": {"$ref": "common.schema.json#/$defs/extensions"},
    "pack_id": {"$ref": "common.schema.json#/$defs/identifier"},
    "pack_version": {"$ref": "common.schema.json#/$defs/semver"},
    "compatible_modeling_ir": {"type": "array", "minItems": 1, "items": {"const": "simulation.model_spec@0.1"}, "uniqueItems": true},
    "method_payload_contracts": {"type": "array", "minItems": 1, "items": {"enum": ["simulation.des_method_payload@0.1", "simulation.abm_method_payload@0.1"]}, "uniqueItems": true},
    "scenario_templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["template_id", "schema_ref"],
        "properties": {
          "template_id": {"$ref": "common.schema.json#/$defs/identifier"},
          "schema_ref": {"type": "string", "minLength": 1, "maxLength": 512}
        }
      }
    },
    "default_experiment_templates": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "metric_definitions": {"type": "array", "minItems": 1, "items": {"$ref": "common.schema.json#/$defs/metricDefinition"}},
    "visualization_hints": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "adapter_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operations", "method_families", "seed_control"],
      "properties": {
        "operations": {"type": "array", "minItems": 1, "items": {"enum": ["model.build", "experiment.run", "result.verify"]}, "uniqueItems": true},
        "method_families": {"type": "array", "minItems": 1, "items": {"$ref": "common.schema.json#/$defs/identifier"}, "uniqueItems": true},
        "seed_control": {"enum": ["required", "supported", "unsupported"]}
      }
    },
    "validation_fixture_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
